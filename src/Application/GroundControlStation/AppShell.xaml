<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="GroundControlStationApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:GroundControlStationApp"
    xmlns:m="http://schemas.enisn-projects.io/dotnet/maui/uraniumui"
    xmlns:uranium="http://schemas.enisn-projects.io/dotnet/maui/uraniumui"
    xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
    xmlns:plain="clr-namespace:Plainer.Maui.Controls;assembly=Plainer.Maui"
    xmlns:input="clr-namespace:InputKit.Shared.Controls;assembly=InputKit.Maui"
    xmlns:settings="clr-namespace:GroundControlStationApp.Views.Settings"
    xmlns:messages="clr-namespace:GroundControlStationApp.Views.Messages"
    xmlns:vehicles="clr-namespace:GroundControlStationApp.Views.Vehicles"
    xmlns:dashboard="clr-namespace:GroundControlStationApp.Views.Dashboard"
    xmlns:appViewModels="clr-namespace:GroundControlStationApp.AppViewModels"
    x:Name="thisShell"
    FlyoutBackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
    Shell.FlyoutBehavior="{OnIdiom Desktop=Locked, Default=Flyout}"
        
    >
    <Shell.Resources>
        <Style TargetType="HorizontalStackLayout" ApplyToDerivedTypes="True" CanCascade="True">
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal" />
                        <VisualState x:Name="Selected">
                            <VisualState.Setters>
                                <Setter Property="BackgroundColor"
                                        Value="{AppThemeBinding Light=#30000000, Dark=#30ffffff}" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>
    </Shell.Resources>
    

    <Shell.FlyoutHeader>
        <VerticalStackLayout StyleClass="PrimaryContainer" Padding="20">
            <Label Text="Swarm Ground Control Station" FontSize="Large" HorizontalTextAlignment="Center" Margin="10" />
            <VerticalStackLayout BindingContext="{uranium:Inject Type={Type appViewModels:ThemeChangeViewModel}}" x:DataType="appViewModels:ThemeChangeViewModel">

                <Label Text="App Theme" HorizontalOptions="Center"/>

                <input:SelectionView HorizontalOptions="Center"
                    ItemsSource="{Binding AppThemeList}" SelectedItem="{Binding SelectedTheme}" 
                    ColumnNumber="2" ColumnSpacing="-2" Color="{StaticResource Tertiary}" >
                </input:SelectionView>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </Shell.FlyoutHeader>

    <Shell.FlyoutContent>
        <Grid RowDefinitions="Auto,*">
            <Grid.BindingContext>
                <appViewModels:AppShellContentViewModel CurrentShell="{x:Reference thisShell}"/>
            </Grid.BindingContext>
            <VerticalStackLayout>
                <VerticalStackLayout Margin="8,8,8,0" BackgroundColor="{AppThemeBinding Light={StaticResource OnSurfaceDark}, Dark={StaticResource OnSurface}}" StyleClass="Elevation1">
                    <plain:EntryView Margin="{OnPlatform Default=0, Android='8,0', iOS='8', MacCatalyst='8'}" Placeholder="Search" Text="{Binding SearchText}" PlaceholderColor="{AppThemeBinding Light={StaticResource OnSurface}, Dark={StaticResource OnSurfaceDark}}" ClearButtonVisibility="WhileEditing"/>
                </VerticalStackLayout>
                <BoxView StyleClass="Divider" />
            </VerticalStackLayout>
            <CollectionView Grid.Row="1" SelectedItem="{Binding SelectedItem}" SelectionMode="Single" ItemsSource="{Binding Items}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <HorizontalStackLayout Padding="20,12" Spacing="12">
                            <Image Source="{Binding Icon}" WidthRequest="20" />
                            <Label Text="{Binding Title}" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </Shell.FlyoutContent>
    



    <FlyoutItem Title="Dashboard">
        <ShellContent
            Title="Dashboard"
            ContentTemplate="{DataTemplate dashboard:DashboardPage}" Route="Dashboard" />
    </FlyoutItem>

    <FlyoutItem Title="Vehicles">
        <ShellContent
            Title="Vehicles"
            ContentTemplate="{DataTemplate vehicles:VehiclesPage}"  Route="Vehicles" />
    </FlyoutItem>

    <FlyoutItem Title="Messages">
        <ShellContent
            Title="Messages"
            ContentTemplate="{DataTemplate messages:MessagesPage}"  Route="Messages" />
    </FlyoutItem>

    <FlyoutItem Title="Settings">
        <ShellContent
            Title="Settings"
            ContentTemplate="{DataTemplate settings:SettingsPage}"  Route="Settings" />
    </FlyoutItem>

</Shell>
