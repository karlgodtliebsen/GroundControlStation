<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:uranium="http://schemas.enisn-projects.io/dotnet/maui/uraniumui"
             xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
             x:Class="GroundControlStationApp.Views.Vehicles.Views.VehiclesView"
             >
    <!--<ContentView.BindingContext>
        <views:VehiclesViewModel/>
    </ContentView.BindingContext>-->

    <uranium:GridLayout  RowCount="3" ColumnCount="1" >

        <material:DataGrid ItemsSource="{Binding VehicleSessions}" UseAutoColumns="True" Margin="30" />

   
        <!--<Button Text="Remove Selected" Command="{Binding RemoveSelectedCommand}" />-->
        <material:DataGrid ItemsSource="{Binding VehicleStates}" SelectedItems="{Binding SelectedItems}"  Margin="30" >
            <material:DataGrid.Columns>
                <material:DataGridSelectionColumn />
                <material:DataGridColumn ValueBinding="{Binding VehicleId}" Title="Identity" />
                <material:DataGridColumn ValueBinding="{Binding CustomMode}" Title="Mode" />
                <material:DataGridColumn ValueBinding="{Binding VehicleType}" Title="Vehicle Type" />
                <material:DataGridColumn ValueBinding="{Binding Autopilot}" Title="Autopilot" />
                <material:DataGridColumn ValueBinding="{Binding BaseMode}" Title="Base Mode" />
                <material:DataGridColumn ValueBinding="{Binding SystemStatus}" Title="System Status" />
                <material:DataGridColumn ValueBinding="{Binding ConnectionState}" Title="Connection State" />
                <material:DataGridColumn ValueBinding="{Binding LastHeartbeatAt}" Title="Last Heartbeat" />
                <material:DataGridColumn ValueBinding="{Binding Mode}" Title="Mode" />
                <material:DataGridColumn ValueBinding="{Binding IsArmed}" Title="Armed State" />
                <material:DataGridColumn ValueBinding="{Binding Latitude}" Title="Latitude" />
                <material:DataGridColumn ValueBinding="{Binding Longitude}" Title="Longitude" />
                <material:DataGridColumn ValueBinding="{Binding Altitude}" Title="Altitude" />
                <material:DataGridColumn ValueBinding="{Binding Roll}" Title="Roll" />
                <material:DataGridColumn ValueBinding="{Binding Pitch}" Title="Pitch" />
                <material:DataGridColumn ValueBinding="{Binding Yaw}" Title="Yaw" />
                <material:DataGridColumn ValueBinding="{Binding BatteryRemaining}" Title="Battery Remaining" />
                <material:DataGridColumn ValueBinding="{Binding BatteryVoltage}" Title="Battery Voltage" />
            </material:DataGrid.Columns>
        </material:DataGrid>


    </uranium:GridLayout>

</ContentView>